{
  "name": "@misunders2d/pi-goal",
  "version": "1.0.0",
  "description": "Fire-and-forget goal mode for Pi with visual planning, autonomous recovery, evidence, and independent completion audit.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "goal",
    "goal-mode",
    "autonomous-agent",
    "agent-loop",
    "planning",
    "verification"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misunders2d/pi-goal.git"
  },
  "homepage": "https://github.com/misunders2d/pi-goal#readme",
  "bugs": {
    "url": "https://github.com/misunders2d/pi-goal/issues"
  },
  "scripts": {
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check:package": "node --experimental-strip-types scripts/check-package.ts",
    "check": "npm run typecheck && npm test && npm run check:package",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "latest",
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "latest",
    "@types/node": "latest",
    "typebox": "latest",
    "typescript": "latest"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/misunders2d/pi-goal/main/media/pi-goal-preview.png"
  },
  "files": [
    "src/",
    "media/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
